<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Echoes of Midnight</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            background: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            font-family: 'Georgia', 'Times New Roman', serif;
        }

        canvas {
            display: block;
            cursor: none;
        }

        #dialogBox {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            width: 720px;
            max-width: 92vw;
            background: rgba(5, 5, 15, 0.96);
            border: 2px solid #334;
            border-radius: 10px;
            padding: 22px 28px;
            color: #ccc;
            font-size: 16px;
            line-height: 1.7;
            z-index: 100;
            box-shadow: 0 0 40px rgba(0,0,0,0.9), inset 0 0 80px rgba(20,20,50,0.3);
        }

        #dialogSpeaker {
            color: #8af;
            font-weight: bold;
            font-size: 13px;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        #dialogText {
            min-height: 44px;
            font-style: italic;
        }

        #dialogContinue {
            text-align: right;
            color: #555;
            animation: blink 1s infinite;
            margin-top: 10px;
            font-size: 13px;
            letter-spacing: 1px;
        }

        #dialogChoices {
            margin-top: 12px;
        }

        #dialogChoices div {
            padding: 10px 14px;
            margin: 5px 0;
            background: rgba(40, 40, 80, 0.5);
            border: 1px solid #445;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            color: #aaa;
        }

        #dialogChoices div:hover {
            background: rgba(70, 70, 140, 0.7);
            border-color: #88f;
            color: #fff;
            transform: translateX(4px);
        }

        #inventory {
            position: fixed;
            top: 12px;
            right: 12px;
            display: flex;
            gap: 5px;
            z-index: 90;
            flex-wrap: wrap;
            max-width: 320px;
        }

        .inv-item {
            width: 46px;
            height: 46px;
            background: rgba(10, 10, 30, 0.88);
            border: 1px solid #334;
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
        }

        .inv-item:hover {
            border-color: #88f;
            transform: scale(1.15);
        }

        .inv-item .tooltip {
            display: none;
            position: absolute;
            bottom: 52px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.96);
            border: 1px solid #556;
            padding: 5px 12px;
            border-radius: 5px;
            font-size: 11px;
            white-space: nowrap;
            color: #bbb;
            font-family: 'Georgia', serif;
        }

        .inv-item:hover .tooltip {
            display: block;
        }

        #journal {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 520px;
            max-width: 92vw;
            max-height: 72vh;
            background: rgba(10, 8, 5, 0.98);
            border: 2px solid #554433;
            border-radius: 10px;
            padding: 28px;
            color: #aa9977;
            z-index: 200;
            overflow-y: auto;
            box-shadow: 0 0 60px rgba(0,0,0,0.95);
        }

        #journal h2 {
            text-align: center;
            color: #ccaa77;
            margin-bottom: 18px;
            font-size: 22px;
        }

        .journal-entry {
            margin-bottom: 14px;
            padding-bottom: 14px;
            border-bottom: 1px solid #332211;
        }

        .journal-loop {
            color: #665544;
            font-size: 11px;
            margin-bottom: 3px;
        }

        .journal-clue {
            color: #ddaa55;
            font-size: 14px;
            line-height: 1.7;
        }

        #journalClose {
            text-align: center;
            margin-top: 18px;
            color: #665544;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: 3px;
            transition: color 0.2s;
        }

        #journalClose:hover {
            color: #ccaa77;
        }

        #levelUpNotice {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #ffdd66;
            font-size: 36px;
            font-weight: bold;
            z-index: 300;
            text-shadow: 0 0 30px #ff8800, 0 0 60px #ff4400;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s;
        }

        #minimap {
            position: fixed;
            bottom: 12px;
            right: 12px;
            width: 160px;
            height: 120px;
            background: rgba(5,5,15,0.85);
            border: 1px solid #334;
            border-radius: 8px;
            z-index: 80;
            overflow: hidden;
        }

        .hidden {
            display: none !important;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.2; }
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
    </style>
</head>
<body>
    <canvas id="gameCanvas"></canvas>

    <div id="dialogBox" class="hidden">
        <div id="dialogSpeaker"></div>
        <div id="dialogText"></div>
        <div id="dialogChoices"></div>
        <div id="dialogContinue">Press SPACE to continue ▼</div>
    </div>

    <div id="inventory" class="hidden"></div>

    <div id="journal" class="hidden">
        <h2>📓 JOURNAL</h2>
        <div id="journalContent"></div>
        <div id="journalClose">[ CLOSE — J ]</div>
    </div>

    <div id="levelUpNotice"></div>
    <canvas id="minimap"></canvas>
    <script src="audio_manager.js"></script>
<script src="achievements.js"></script>
    <script src="particles.js"></script>
<script src="events.js"></script>
    <script src="combat.js"></script>
<script src="achievements.js"></script>
    <script src="particles.js"></script>
    <script src="events.js"></script>
    <script src="combat.js"></script>
    <script src="rooms.js"></script>
    <script src="game.js"></script>
</body>
</html>